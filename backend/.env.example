
// Backend .env example - copy this to `.env` in the backend folder and set values.
# Do NOT commit real secrets to the repository. This file is for local guidance only.

# MongoDB connection string (example for MongoDB Atlas or local mongodb)
# e.g. MONGO_URI=mongodb+srv://<user>:<pass>@cluster0.mongodb.net/mydb?retryWrites=true&w=majority
PORT=5000
MONGO_URI=mongodb+srv://<DB_USER>:<DB_PASSWORD>@cluster0.mongodb.net/<DB_NAME>?retryWrites=true&w=majority
JWT_SECRET=your_jwt_secret_here
NODE_ENV=production


CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_key
CLOUDINARY_API_SECRET=your_cloudinary_secret


# SMTP (Brevo / Sendinblue) credentials
SMTP_PASS=your_smtp_password
SMTP_SERVER=smtp.example.com
SMTP_PORT=587
SMTP_LOGIN=your_smtp_login@example.com


